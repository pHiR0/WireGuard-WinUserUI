<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WireGuard.UI.ViewModels"
        xmlns:models="using:WireGuard.Shared.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="WireGuard.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="WireGuard Manager"
        Width="900" Height="600"
        MinWidth="720" MinHeight="500"
        RequestedThemeVariant="Dark">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel Margin="16">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="WireGuard Manager" FontSize="22" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </StackPanel>

        <!-- Error banner -->
        <Border DockPanel.Dock="Top" Background="#3D1010" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,8"
                IsVisible="{Binding HasError}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Bottom status toolbar -->
        <Border DockPanel.Dock="Bottom" Background="#16213A"
                Padding="12,5" Margin="-16,8,-16,-16">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Width="8" Height="8" CornerRadius="4"
                        Background="{Binding ServiceStatusColor}"
                        VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ServiceStatusText}" FontSize="11"
                           Foreground="#94A3B8" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main content (always visible, commands guard when not connected) -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">

            <!-- ==================== TAB: Túneles ==================== -->
            <TabItem Header="Túneles">
                <DockPanel>
                    <!-- Toolbar -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8"
                                Margin="0,8,0,12">
                        <Button Content="Actualizar" Command="{Binding RefreshTunnelsCommand}"
                                IsEnabled="{Binding !IsRefreshing}"/>
                    </StackPanel>

                    <!-- Tunnel List -->
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Tunnels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TunnelViewModel">
                                    <Border Background="#252B3A" CornerRadius="8"
                                            Padding="16,12" Margin="0,0,0,8">
                                        <DockPanel>
                                            <!-- Status indicator + Name -->
                                            <StackPanel Orientation="Horizontal" Spacing="10"
                                                        VerticalAlignment="Center">
                                                <Border Width="10" Height="10" CornerRadius="5"
                                                        Background="{Binding StatusColor}"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               FontSize="14"/>
                                                    <TextBlock Text="{Binding StatusText}" FontSize="12"
                                                               Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Action buttons -->
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Content="Conectar"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).StartTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding CanStart}"
                                                        IsEnabled="{Binding !IsLoading}"
                                                        Classes="accent"/>
                                                <Button Content="Desconectar"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).StopTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding CanStop}"
                                                        IsEnabled="{Binding !IsLoading}"/>
                                                <Button Content="Reiniciar"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RestartTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding CanStop}"
                                                        IsEnabled="{Binding !IsLoading}"/>
                                                <Button Content="Editar"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).EditTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding !IsLoading}"
                                                        IsVisible="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).IsAdvancedOperator}"/>
                                                <Button Content="Eliminar"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).DeleteTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding !IsLoading}"
                                                        Foreground="#F87171"/>
                                                <Button Content="Exportar"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).ExportTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding !IsLoading}"/>
                                                <TextBlock Text="..." IsVisible="{Binding IsPending}"
                                                           VerticalAlignment="Center" Foreground="#94A3B8"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ==================== TAB: Importar/Editar Túnel ==================== -->
            <TabItem x:DataType="vm:MainWindowViewModel"
                     IsVisible="{Binding IsAdvancedOperator}">
                <TabItem.Header>
                    <TextBlock Text="{Binding ImportTunnel.TabTitle, FallbackValue='Importar'}"/>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Spacing="12" Margin="0,8"
                                DataContext="{Binding ImportTunnel}"
                                x:DataType="vm:ImportTunnelViewModel">

                        <TextBlock Text="Importar Túnel WireGuard" FontSize="16" FontWeight="SemiBold"/>

                        <!-- Tunnel name -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Nombre del túnel" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox Text="{Binding TunnelName}" Watermark="ej. oficina-vpn"/>
                        </StackPanel>

                        <!-- Conf content -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Configuración (contenido .conf)" FontWeight="SemiBold" FontSize="13"/>
                            <TextBox Text="{Binding ConfContent}" AcceptsReturn="True"
                                     Height="200" Watermark="Pega aquí el contenido .conf..."
                                     FontFamily="Consolas, Courier New, monospace" FontSize="12"/>
                        </StackPanel>

                        <!-- Validation message -->
                        <Border Background="#0D2B1A" CornerRadius="4" Padding="8,6"
                                IsVisible="{Binding IsValid}">
                            <TextBlock Text="{Binding ValidationMessage}" Foreground="#86EFAC"
                                       TextWrapping="Wrap" FontSize="12"/>
                        </Border>
                        <Border Background="#3D1010" CornerRadius="4" Padding="8,6"
                                IsVisible="{Binding ValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding ValidationMessage}" Foreground="#FCA5A5"
                                       TextWrapping="Wrap" FontSize="12"
                                       IsVisible="{Binding !IsValid}"/>
                        </Border>

                        <!-- Error message -->
                        <Border Background="#3D1010" CornerRadius="4" Padding="8,6"
                                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Success message -->
                        <Border Background="#0D2B1A" CornerRadius="4" Padding="8,6"
                                IsVisible="{Binding ImportSuccess}">
                            <TextBlock Text="Túnel importado correctamente." Foreground="#86EFAC"/>
                        </Border>

                        <Button Content="{Binding ButtonText, FallbackValue='Importar Túnel'}" Command="{Binding ImportCommand}"
                                IsEnabled="{Binding !IsImporting}"
                                HorizontalAlignment="Left"
                                Classes="accent"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== TAB: Usuarios ==================== -->
            <TabItem Header="Usuarios" x:DataType="vm:MainWindowViewModel"
                     IsVisible="{Binding IsAdmin}">
                <DockPanel DataContext="{Binding UserManagement}"
                           x:DataType="vm:UserManagementViewModel">

                    <!-- Error -->
                    <Border DockPanel.Dock="Top" Background="#3D1010" CornerRadius="4"
                            Padding="12,8" Margin="0,8,0,8"
                            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Add user form -->
                    <Border DockPanel.Dock="Top" Background="#252B3A" CornerRadius="8"
                            Padding="12" Margin="0,0,0,12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Añadir Usuario" FontWeight="SemiBold" FontSize="14"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Text="{Binding NewUsername}" Watermark="Nombre de usuario Windows" Width="200"/>
                                <ComboBox ItemsSource="{Binding AvailableRoles}" SelectedItem="{Binding NewUserRole}" Width="160"/>
                                <Button Content="Añadir" Command="{Binding AddUserCommand}"
                                        Classes="accent"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Toolbar -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <Button Content="Actualizar usuarios" Command="{Binding LoadUsersCommand}"
                                IsEnabled="{Binding !IsLoading}"/>
                    </StackPanel>

                    <!-- User list -->
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Users}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:UserViewModel">
                                    <Border Background="#252B3A" CornerRadius="8"
                                            Padding="16,10" Margin="0,0,0,6">
                                        <DockPanel>
                                            <TextBlock Text="{Binding Username}" FontWeight="SemiBold"
                                                       FontSize="14" VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <ComboBox ItemsSource="{Binding $parent[ItemsControl].((vm:UserManagementViewModel)DataContext).AvailableRoles}"
                                                          SelectedItem="{Binding Role}" Width="150"/>
                                                <Button Content="Guardar"
                                                        Command="{Binding $parent[ItemsControl].((vm:UserManagementViewModel)DataContext).ChangeRoleCommand}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Eliminar"
                                                        Command="{Binding $parent[ItemsControl].((vm:UserManagementViewModel)DataContext).RemoveUserCommand}"
                                                        CommandParameter="{Binding}"
                                                        Foreground="#F87171"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ==================== TAB: Auditoría ==================== -->
            <TabItem Header="Auditoría" x:DataType="vm:MainWindowViewModel"
                     IsVisible="{Binding IsAdmin}">
                <DockPanel DataContext="{Binding AuditLog}"
                           x:DataType="vm:AuditLogViewModel">

                    <!-- Error -->
                    <Border DockPanel.Dock="Top" Background="#3D1010" CornerRadius="4"
                            Padding="12,8" Margin="0,8,0,8"
                            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Filters -->
                    <Border DockPanel.Dock="Top" Background="#252B3A" CornerRadius="8"
                            Padding="12" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{Binding FilterUsername}" Watermark="Filtrar por usuario" Width="150"/>
                            <TextBox Text="{Binding FilterAction}" Watermark="Filtrar por acción" Width="150"/>
                            <Button Content="Aplicar" Command="{Binding ApplyFilterCommand}"/>
                            <Button Content="Actualizar" Command="{Binding LoadCommand}"
                                    IsEnabled="{Binding !IsLoading}"/>
                        </StackPanel>
                    </Border>

                    <!-- Pagination -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Button Content="Anterior" Command="{Binding PreviousPageCommand}"
                                IsEnabled="{Binding CanGoBack}"/>
                        <TextBlock VerticalAlignment="Center" FontSize="12">
                            <Run Text="Página "/>
                            <Run Text="{Binding CurrentPage}"/>
                            <Run Text=" de "/>
                            <Run Text="{Binding TotalPages}"/>
                            <Run Text=" ("/>
                            <Run Text="{Binding TotalCount}"/>
                            <Run Text=" entradas)"/>
                        </TextBlock>
                        <Button Content="Siguiente" Command="{Binding NextPageCommand}"
                                IsEnabled="{Binding CanGoForward}"/>
                    </StackPanel>

                    <!-- Audit entries -->
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Entries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:AuditEntryDto">
                                    <Border Background="#252B3A" CornerRadius="6"
                                            Padding="12,8" Margin="0,0,0,4">
                                        <DockPanel>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                               FontSize="11" Foreground="#94A3B8" Width="130"/>
                                                    <TextBlock Text="{Binding Username}" FontWeight="SemiBold" FontSize="12" Width="120"/>
                                                    <TextBlock Text="{Binding Action}" FontSize="12" Width="130"/>
                                                    <TextBlock Text="{Binding Tunnel}" FontSize="12" Foreground="#94A3B8" Width="120"/>
                                                    <TextBlock Text="{Binding Result}" FontSize="12" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Error}" FontSize="11" Foreground="#FB923C"
                                                           IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ==================== TAB: Configuración ==================== -->
            <TabItem Header="Configuración">
                <ScrollViewer>
                    <StackPanel Spacing="16" Margin="0,8"
                                DataContext="{Binding Settings}"
                                x:DataType="vm:SettingsViewModel">

                        <TextBlock Text="Configuración de la aplicación" FontSize="16" FontWeight="SemiBold"/>

                        <!-- Intervalo de actualización -->
                        <Border Background="#252B3A" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Actualización automática" FontWeight="SemiBold" FontSize="14"/>
                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock Text="Intervalo (segundos):" FontSize="13" VerticalAlignment="Center"/>
                                    <NumericUpDown Value="{Binding RefreshIntervalSeconds}"
                                                  Minimum="1" Maximum="300" Increment="1"
                                                  Width="100"/>
                                </StackPanel>
                                <TextBlock Text="Define cada cuántos segundos se actualiza la lista de túneles."
                                           FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Notificaciones -->
                        <Border Background="#252B3A" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Notificaciones" FontWeight="SemiBold" FontSize="14"/>
                                <CheckBox Content="Activar notificaciones de Windows cuando un túnel se conecta o desconecta"
                                          IsChecked="{Binding EnableNotifications}"/>
                            </StackPanel>
                        </Border>

                        <!-- Bandeja del sistema -->
                        <Border Background="#252B3A" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Bandeja del sistema" FontWeight="SemiBold" FontSize="14"/>
                                <CheckBox Content="Minimizar a la bandeja del sistema en lugar de cerrar"
                                          IsChecked="{Binding MinimizeToTray}"/>
                                <CheckBox Content="Iniciar minimizado en la bandeja"
                                          IsChecked="{Binding StartMinimized}"/>
                            </StackPanel>
                        </Border>

                        <!-- Guardar -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="Guardar configuración" Command="{Binding SaveCommand}"
                                    Classes="accent"/>
                            <TextBlock Text="{Binding SavedMessage}" VerticalAlignment="Center"
                                       Foreground="#86EFAC" FontSize="12"
                                       IsVisible="{Binding SavedMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
