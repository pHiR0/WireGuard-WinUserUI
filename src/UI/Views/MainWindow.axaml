<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WireGuard.UI.ViewModels"
        xmlns:models="using:WireGuard.Shared.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="WireGuard.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="WireGuard Manager"
        Icon="/Assets/icon.ico"
        Width="900" Height="600"
        MinWidth="720" MinHeight="500"
        RequestedThemeVariant="Dark">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel Margin="16">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <DockPanel>
                <Image Source="/Assets/icon_32.png" Width="28" Height="28"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="WireGuard Manager" FontSize="22" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </StackPanel>

        <!-- Error banner -->
        <Border DockPanel.Dock="Top" Background="#3D1010" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,8"
                IsVisible="{Binding HasError}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- WireGuard not installed warning -->
        <Border DockPanel.Dock="Top" Background="#3D2800" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,8"
                IsVisible="{Binding !IsWireGuardInstalled}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="⚠" Foreground="#FCD34D" FontSize="16" VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Foreground="#FCD34D" Text="WireGuard no está instalado. Las operaciones sobre túneles no estarán disponibles."/>
                    <TextBlock Foreground="#FCD34D" Text="Descárguelo desde wireguard.com e instálelo para continuar."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Bottom status toolbar -->
        <Border DockPanel.Dock="Bottom" Background="#16213A"
                Padding="12,5" Margin="-16,8,-16,-16">
            <DockPanel>
                <!-- Right side: role badge only -->
                <Border DockPanel.Dock="Right" Background="#1E3A5F" CornerRadius="4" Padding="6,2"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsConnected}">
                    <TextBlock Text="{Binding CurrentRoleText}" FontSize="11"
                               Foreground="#60A5FA" VerticalAlignment="Center"/>
                </Border>
                <!-- Left side: connection dot -->
                <Border DockPanel.Dock="Left" Width="8" Height="8" CornerRadius="4"
                        Background="{Binding ServiceStatusColor}"
                        VerticalAlignment="Center" Margin="0,0,10,0"/>
                <!-- Center: public IP + refresh button -->
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                            IsVisible="{Binding IsConnected}">
                    <TextBlock Text="IP pública:" FontSize="11" Foreground="#64748B"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PublicIp, FallbackValue='—'}" FontSize="11"
                               Foreground="#94A3B8" VerticalAlignment="Center"
                               IsVisible="{Binding !IsRefreshingPublicIp}"/>
                    <!-- Indeterminate bar shown while refreshing -->
                    <ProgressBar IsIndeterminate="True" Width="36" Height="3"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsRefreshingPublicIp}"/>
                    <!-- Refresh button (hidden while a refresh is already in progress) -->
                    <Button Command="{Binding RefreshPublicIpCommand}"
                            IsVisible="{Binding !IsRefreshingPublicIp}"
                            Padding="2,0" Background="Transparent" BorderThickness="0"
                            ToolTip.Tip="Refrescar IP pública">
                        <TextBlock Text="↺" FontSize="12" Foreground="#60A5FA"
                                   VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content (always visible, commands guard when not connected) -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">

            <!-- ==================== TAB: Túneles ==================== -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#x1F5A7;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="Túneles" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel>
                    <!-- Toolbar: create/import buttons (only for AdvancedOperator+) -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8"
                                Margin="0,8,0,10"
                                IsVisible="{Binding IsAdvancedOperator}">
                        <Button Command="{Binding NewTunnelCommand}"
                                ToolTip.Tip="Crear nuevo túnel">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="＋" FontSize="13"/>
                                <TextBlock Text="Nuevo túnel" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ImportTunnelFileCommand}"
                                ToolTip.Tip="Importar configuración desde .conf">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="📂" FontSize="11"/>
                                <TextBlock Text="Importar .conf" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Tunnel List with watermark background -->
                    <Grid>
                        <Image Source="/Assets/icon_256.png" Opacity="0.04"
                               Width="280" Height="280"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                        <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Tunnels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TunnelViewModel">
                                    <Border Background="{Binding CardBackground}" CornerRadius="8"
                                            Padding="16,12" Margin="0,0,0,8">
                                        <StackPanel>
                                        <DockPanel>
                                            <!-- Status indicator + Name -->
                                            <StackPanel Orientation="Horizontal" Spacing="10"
                                                        VerticalAlignment="Center">
                                                <Border Width="10" Height="10" CornerRadius="5"
                                                        Background="{Binding StatusColor}"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               FontSize="14"/>
                                                    <TextBlock Text="{Binding StatusText}" FontSize="12"
                                                               Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Action buttons -->
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).StartTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding CanStart}"
                                                        IsEnabled="{Binding !IsLoading}"
                                                        Classes="accent"
                                                        ToolTip.Tip="Conectar">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="▶" FontSize="11"/>
                                                        <TextBlock Text="Conectar" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).StopTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding CanStop}"
                                                        IsEnabled="{Binding !IsLoading}"
                                                        ToolTip.Tip="Desconectar">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="⏹" FontSize="11"/>
                                                        <TextBlock Text="Desconectar" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).RestartTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding CanStop}"
                                                        IsEnabled="{Binding !IsLoading}"
                                                        ToolTip.Tip="Reiniciar">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="↺" FontSize="11"/>
                                                        <TextBlock Text="Reiniciar" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).EditTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding !IsLoading}"
                                                        IsVisible="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).IsAdvancedOperator}"
                                                        ToolTip.Tip="Editar configuración">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="✏" FontSize="11"/>
                                                        <TextBlock Text="Editar" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).DeleteTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding !IsLoading}"
                                                        Foreground="#F87171"
                                                        ToolTip.Tip="Eliminar túnel">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="🗑" FontSize="11"/>
                                                        <TextBlock Text="Eliminar" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).ExportTunnelCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding !IsLoading}"
                                                        ToolTip.Tip="Exportar configuración">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="⬇" FontSize="11"/>
                                                        <TextBlock Text="Exportar" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                                <TextBlock Text="..." IsVisible="{Binding IsPending}"
                                                           VerticalAlignment="Center" Foreground="#94A3B8"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <!-- Detalles del túnel (visibles cuando está conectado y hay datos) -->
                                        <Border Margin="20,6,0,0"
                                                IsVisible="{Binding HasDetails}">
                                            <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="IP del túnel:"
                                                           FontSize="11" Foreground="#94A3B8"
                                                           IsVisible="{Binding TunnelAddress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TunnelAddress}"
                                                           FontSize="11"
                                                           IsVisible="{Binding TunnelAddress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Endpoint:"
                                                           FontSize="11" Foreground="#94A3B8"
                                                           IsVisible="{Binding Endpoint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Endpoint}"
                                                           FontSize="11"
                                                           IsVisible="{Binding Endpoint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Último contacto:"
                                                           FontSize="11" Foreground="#94A3B8"
                                                           IsVisible="{Binding LastHandshake, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastHandshake}"
                                                           FontSize="11"
                                                           IsVisible="{Binding LastHandshake, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Tráfico:"
                                                           FontSize="11" Foreground="#94A3B8"
                                                           IsVisible="{Binding TransferText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TransferText}"
                                                           FontSize="11"
                                                           IsVisible="{Binding TransferText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Conectado:"
                                                           FontSize="11" Foreground="#94A3B8"
                                                           IsVisible="{Binding ConnectionTimeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ConnectionTimeText}"
                                                           FontSize="11"
                                                           IsVisible="{Binding ConnectionTimeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            </Grid>
                                        </Border>

                                        <!-- Toggle inicio automático (solo AdvancedOperator+) -->
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0"
                                                    IsVisible="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).IsAdvancedOperator}">
                                            <TextBlock Text="Inicio automático" FontSize="11"
                                                       Foreground="#94A3B8" VerticalAlignment="Center"/>
                                            <ToggleSwitch IsChecked="{Binding AutoStart}"
                                                          Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).SetTunnelAutoStartCommand}"
                                                          CommandParameter="{Binding}"
                                                          OnContent="" OffContent=""
                                                          Padding="0" Margin="0,-4,0,-4"/>
                                        </StackPanel>
                                    </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ==================== TAB: Auditoría ==================== -->
            <TabItem x:DataType="vm:MainWindowViewModel"
                     IsVisible="{Binding IsAdmin}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#x1F4CB;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="Auditoría" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel DataContext="{Binding AuditLog}"
                           x:DataType="vm:AuditLogViewModel">

                    <!-- Error -->
                    <Border DockPanel.Dock="Top" Background="#3D1010" CornerRadius="4"
                            Padding="12,8" Margin="0,8,0,8"
                            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Filters -->
                    <Border DockPanel.Dock="Top" Background="#252B3A" CornerRadius="8"
                            Padding="12" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{Binding FilterUsername}" Watermark="Filtrar por usuario" Width="150"/>
                            <TextBox Text="{Binding FilterAction}" Watermark="Filtrar por acción" Width="150"/>
                            <Button Content="Aplicar" Command="{Binding ApplyFilterCommand}"/>
                            <Button Content="Actualizar" Command="{Binding LoadCommand}"
                                    IsEnabled="{Binding !IsLoading}"/>
                        </StackPanel>
                    </Border>

                    <!-- Pagination -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Button Content="Anterior" Command="{Binding PreviousPageCommand}"
                                IsEnabled="{Binding CanGoBack}"/>
                        <TextBlock VerticalAlignment="Center" FontSize="12">
                            <Run Text="Página "/>
                            <Run Text="{Binding CurrentPage}"/>
                            <Run Text=" de "/>
                            <Run Text="{Binding TotalPages}"/>
                            <Run Text=" ("/>
                            <Run Text="{Binding TotalCount}"/>
                            <Run Text=" entradas)"/>
                        </TextBlock>
                        <Button Content="Siguiente" Command="{Binding NextPageCommand}"
                                IsEnabled="{Binding CanGoForward}"/>
                    </StackPanel>

                    <!-- Audit entries -->
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Entries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:AuditEntryDto">
                                    <Border Background="#252B3A" CornerRadius="6"
                                            Padding="12,8" Margin="0,0,0,4">
                                        <DockPanel>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                               FontSize="11" Foreground="#94A3B8" Width="130"/>
                                                    <TextBlock Text="{Binding Username}" FontWeight="SemiBold" FontSize="12" Width="120"/>
                                                    <TextBlock Text="{Binding Action}" FontSize="12" Width="130"/>
                                                    <TextBlock Text="{Binding Tunnel}" FontSize="12" Foreground="#94A3B8" Width="120"/>
                                                    <TextBlock Text="{Binding Result}" FontSize="12" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Error}" FontSize="11" Foreground="#FB923C"
                                                           IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ==================== TAB: Configuración ==================== -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#x2699;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="Configuración" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Spacing="16" Margin="0,8"
                                DataContext="{Binding Settings}"
                                x:DataType="vm:SettingsViewModel">

                        <TextBlock Text="Configuración de la aplicación" FontSize="16" FontWeight="SemiBold"/>

                        <!-- Notificaciones -->
                        <Border Background="#252B3A" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Notificaciones" FontWeight="SemiBold" FontSize="14"/>
                                <ToggleSwitch IsChecked="{Binding EnableNotifications}"
                                             OnContent="Notificaciones activadas"
                                             OffContent="Notificaciones desactivadas"/>
                            </StackPanel>
                        </Border>

                        <!-- Bandeja del sistema -->
                        <Border Background="#252B3A" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Bandeja del sistema" FontWeight="SemiBold" FontSize="14"/>
                                <ToggleSwitch IsChecked="{Binding MinimizeToTray}"
                                             OnContent="Al cerrar, enviar a la bandeja (no salir)"
                                             OffContent="Al cerrar, salir de la aplicación"/>
                                <ToggleSwitch IsChecked="{Binding StartMinimized}"
                                             OnContent="Iniciar minimizado en la bandeja"
                                             OffContent="Iniciar con la ventana visible"/>
                            </StackPanel>
                        </Border>

                        <!-- Inicio con Windows -->
                        <Border Background="#252B3A" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Inicio con Windows" FontWeight="SemiBold" FontSize="14"/>
                                <ToggleSwitch IsChecked="{Binding StartWithWindows}"
                                             OnContent="Iniciar la UI automáticamente al iniciar sesión"
                                             OffContent="No iniciar automáticamente con Windows"/>
                            </StackPanel>
                        </Border>

                        <!-- Resolución de IP pública -->
                        <Border Background="#252B3A" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Resolución de IP pública" FontWeight="SemiBold" FontSize="14"/>

                                <!-- Servicio principal -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Servicio principal:" Foreground="#94A3B8"
                                               VerticalAlignment="Center" Width="130"/>
                                    <ComboBox ItemsSource="{Binding PublicIpProviders}"
                                              SelectedItem="{Binding SelectedPrimaryProvider}"
                                              MinWidth="200">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PublicIpProviderViewModel">
                                                <TextBlock Text="{Binding DisplayName}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Command="{Binding SelectedPrimaryProvider.TestCommand}"
                                            IsEnabled="{Binding SelectedPrimaryProvider.IsTesting, Converter={x:Static BoolConverters.Not}}"
                                            Padding="8,4" Content="Probar"
                                            ToolTip.Tip="Probar el servicio principal ahora"/>
                                    <TextBlock Text="{Binding SelectedPrimaryProvider.TestResult}"
                                               VerticalAlignment="Center"
                                               Foreground="#94A3B8" FontSize="11"/>
                                </StackPanel>

                                <TextBlock Text="Fallbacks (en orden):" Foreground="#94A3B8"
                                           FontSize="12" Margin="0,6,0,0"/>

                                <!-- Lista de fallbacks -->
                                <ItemsControl ItemsSource="{Binding PublicIpProviders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PublicIpProviderViewModel">
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,3,0,0"
                                                        IsVisible="{Binding !IsPrimary}">
                                                <ToggleSwitch IsChecked="{Binding IsEnabled}"
                                                              OnContent="" OffContent=""
                                                              Padding="0" Margin="0,-6,0,-6"/>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           VerticalAlignment="Center" MinWidth="160"
                                                           FontSize="12"/>
                                                <Button Command="{Binding TestCommand}"
                                                        IsEnabled="{Binding !IsTesting}"
                                                        Padding="6,3" Content="Probar" FontSize="11"/>
                                                <TextBlock Text="{Binding TestResult}"
                                                           VerticalAlignment="Center"
                                                           Foreground="#94A3B8" FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ==================== TAB: Acerca de ==================== -->
            <TabItem x:DataType="vm:MainWindowViewModel">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#x2139;" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="Acerca de" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="24" MaxWidth="520" HorizontalAlignment="Center">

                        <!-- Logo + nombre -->
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <Image Source="/Assets/icon_32.png" Width="72" Height="72"
                                   HorizontalAlignment="Center"/>
                            <TextBlock Text="WireGuard Manager" FontSize="22" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Interfaz de usuario para WireGuard en Windows"
                                       FontSize="13" Foreground="#94A3B8"
                                       HorizontalAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>

                        <!-- Info -->
                        <Border Background="#252B3A" CornerRadius="8" Padding="16">
                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Versión:"
                                           Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding AppVersion}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Autor:"
                                           Foreground="#94A3B8" Margin="0,8,0,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="pHiR0"
                                           Margin="0,8,0,0" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Repositorio:"
                                           Foreground="#94A3B8" Margin="0,8,0,0"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Row="2" Grid.Column="1"
                                        Command="{Binding OpenGitHubCommand}"
                                        Margin="0,6,0,0" Padding="8,4"
                                        ToolTip.Tip="https://github.com/pHiR0/WireGuard-WinUserUI">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="⬛" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Text="GitHub — pHiR0/WireGuard-WinUserUI"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Descripción -->
                        <Border Background="#252B3A" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Descripción" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#CBD5E1"
                                           Text="WireGuard Manager es una interfaz de usuario de escritorio para gestionar túneles WireGuard en Windows. Permite crear, editar, importar y monitorizar túneles VPN a través de un servicio Windows con control de acceso por roles (Admin, AdvancedOperator, Operator, Viewer)."/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
