<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WireGuard.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="WireGuard.UI.Views.TunnelEditorWindow"
        x:DataType="vm:TunnelEditorViewModel"
        Title="{Binding WindowTitle}"
        Icon="/Assets/icon.ico"
        Width="680" Height="560"
        MinWidth="540" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        RequestedThemeVariant="Dark"
        CanResize="True">

    <DockPanel Margin="20">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16" Spacing="4">
            <TextBlock Text="{Binding WindowTitle}" FontSize="18" FontWeight="Bold"/>
            <TextBlock FontSize="12" Foreground="#94A3B8"
                       Text="Introduce el nombre y la configuración .conf del túnel."/>
        </StackPanel>

        <!-- Bottom action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar"
                    Command="{Binding CancelCommand}"
                    IsEnabled="{Binding !IsSaving}"/>
            <Button Content="{Binding SaveButtonText}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsValid}"
                    Classes="accent"/>
        </StackPanel>

        <ScrollViewer>
            <StackPanel Spacing="14">

                <!-- Tunnel name -->
                <Border Background="#252B3A" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Nombre del túnel" FontWeight="SemiBold" FontSize="14"/>
                        <TextBox Text="{Binding TunnelName}"
                                 Watermark="ej. oficina-vpn"
                                 IsReadOnly="{Binding IsEditMode}"/>
                        <TextBlock FontSize="11" Foreground="#94A3B8"
                                   IsVisible="{Binding IsEditMode}"
                                   Text="El nombre del túnel no puede modificarse. Para renombrar, elimine el túnel y cree uno nuevo."/>
                    </StackPanel>
                </Border>

                <!-- Conf content -->
                <Border Background="#252B3A" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <DockPanel>
                            <TextBlock Text="Configuración (.conf)" FontWeight="SemiBold" FontSize="14"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding LoadFromFileCommand}"
                                    IsVisible="{Binding !IsEditMode}"
                                    ToolTip.Tip="Cargar desde archivo .conf">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="📂" FontSize="11"/>
                                    <TextBlock Text="Cargar .conf" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </DockPanel>
                        <TextBox Text="{Binding ConfContent}"
                                 AcceptsReturn="True"
                                 Height="240"
                                 Watermark="Pega aquí el contenido .conf o usa el botón Cargar..."
                                 FontFamily="Consolas, Courier New, monospace"
                                 FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Validation message (success/warnings) -->
                <Border Background="#0D2B1A" CornerRadius="4" Padding="10,6"
                        IsVisible="{Binding IsValid}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="✔" Foreground="#4ADE80" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ValidationMessage}" Foreground="#86EFAC"
                                   TextWrapping="Wrap" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Validation errors -->
                <Border Background="#3D1010" CornerRadius="4" Padding="10,6"
                        IsVisible="{Binding ValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding ValidationMessage}" Foreground="#FCA5A5"
                               TextWrapping="Wrap" FontSize="12"
                               IsVisible="{Binding !IsValid}"/>
                </Border>

                <!-- API/service error -->
                <Border Background="#3D1010" CornerRadius="4" Padding="10,6"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="✖" Foreground="#F87171" VerticalAlignment="Top" Margin="0,1,0,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5"
                                   TextWrapping="Wrap" FontSize="12"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
