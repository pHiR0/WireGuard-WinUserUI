<?xml version="1.0" encoding="utf-8"?>
<!--
  Product.wxs — Definición principal del paquete WiX v4/v5
  Documentación WiX v5: https://wixtoolset.org/docs/
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
    Name="WireGuard Manager"
    Manufacturer="pHiR0"
    Version="1.0.0.0"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes"
    Language="3082">

    <!--
      MajorUpgrade: al instalar una versión más reciente, elimina la anterior automáticamente.
      Si se intenta instalar una versión más antigua, muestra un mensaje de error.
    -->
    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="Ya hay instalada una versión más reciente de WireGuard Manager. Desinstálala antes de continuar." />

    <!-- Empaqueta todos los ficheros en el MSI (cabinet embebido) -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Interfaz de instalador mínima con solo la pantalla de licencia + progreso -->
    <ui:WixUI Id="WixUI_Minimal" />

    <!-- Condición: requiere Windows 10 o superior (64 bits).
         VersionNT = major*100+minor: Windows 10/11 = 1000, Win8.1 = 603.
         El OSS Build number no está disponible como propiedad MSI estándar;
         el target net8.0-windows10.0.17763.0 ya garantiza el build mínimo en runtime. -->
    <Launch
      Condition="VersionNT64 >= 1000"
      Message="WireGuard Manager requiere Windows 10 o superior (64 bits)." />

    <!-- Referencias a los grupos de componentes definidos en Components.wxs -->
    <Feature Id="FeatureMain" Title="WireGuard Manager" Level="1">
      <ComponentGroupRef Id="CG_Service" />
      <ComponentGroupRef Id="CG_UI" />
      <ComponentGroupRef Id="CG_Shortcuts" />
    </Feature>

  </Package>
</Wix>
